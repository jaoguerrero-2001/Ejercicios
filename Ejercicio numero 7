class Perro:
    def __init__(self, nombre, raza, edad, peso):
        self.nombre = nombre
        self.raza = raza
        self.edad = edad
        self.peso = peso

    def ladrar(self):
        print(f"{self.nombre} está ladrando: ¡Guau guau!")

perro1 = Perro("Firulais", "Labrador", 5, "25 kg")
perro1.ladrar()
